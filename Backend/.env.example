# Backend Configuration

# Server Port
PORT=8000

# MongoDB Atlas Connection String
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?ssl=true&replicaSet=atlas-shard-0&authSource=admin&appName=AIHabitTracker

# Local MongoDB Connection (fallback)
MONGO_URI_LOCAL=mongodb://127.0.0.1:27017/aihabittracker

# JWT Configuration
JWT_SECRET=your-long-random-secret-key-here-at-least-32-characters
JWT_EXPIRES_IN=30d

# Google Gemini AI API (Optional - for AI features)
GEMINI_API_KEY=your-google-genai-api-key-here
GEMINI_MODEL=gemini-3.5-flash

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
